# ============================================================================
# OWASP Shield Desk — Scanner Backend configuration
# Copy this file to ".env" and fill in the values.
# ============================================================================

# Port the scanner API listens on
PORT=8787

# --- Supabase (same project as the frontend) ---
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# SERVICE ROLE key (Settings -> API -> service_role secret).
# NEVER expose this in the frontend. It bypasses RLS and is used only here,
# server-side, to write scan results and to verify user JWTs.
SUPABASE_SERVICE_ROLE_KEY=

# --- CORS ---
# Comma-separated list of frontend origins allowed to call this backend.
# Include your local Vite dev server AND your deployed Vercel URL.
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080

# --- Safety / scope ---
# When false (default) the scanner refuses private / loopback / cloud-metadata
# targets (SSRF protection). Set to "true" ONLY for local testing against your
# own machine (e.g. scanning http://localhost:3000).
ALLOW_PRIVATE_TARGETS=false

# Max scans a single user may start per hour
RATE_LIMIT_PER_HOUR=5

# Global cap on scans running at the same time (protects a shared host).
MAX_CONCURRENT_SCANS=3

# Optional allowlist of user emails permitted to scan (comma-separated).
# Empty = any logged-in user (fine locally). SET THIS before hosting publicly
# so strangers can't use your server as an attack platform.
SCAN_ALLOWED_EMAILS=

# Hard cap on a single scan's wall-clock duration (milliseconds).
# Real deep scans (nuclei full templates, nikto, wpscan) can take a while.
MAX_SCAN_DURATION_MS=1800000

# --- Optional external CLI tools (hybrid mode) ---
# Real Kali tools are auto-used when installed (they are, in the Docker image).
# Set to "false" to force-disable even if installed.
ENABLE_NMAP=true
ENABLE_NUCLEI=true

# Wordlist for gobuster/ffuf (Kali default path; set in the Docker image).
DIR_WORDLIST=/usr/share/wordlists/dirb/common.txt

# Optional: WPScan API token for richer WordPress vuln data (https://wpscan.com).
WPSCAN_API_TOKEN=
